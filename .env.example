# ============================================================
# Credenciales del Asistente de Voz "Kiro"
# ============================================================
# Copia este archivo como .env y completa con tus credenciales:
#   cp .env.example .env

# Credenciales AWS (necesarias para Amazon Polly – voz de respuesta)
AWS_ACCESS_KEY_ID=tu_access_key_aqui
AWS_SECRET_ACCESS_KEY=tu_secret_key_aqui
AWS_DEFAULT_REGION=us-east-1

# DeepSeek API (necesaria para respuestas inteligentes a preguntas generales)
DEEPSEEK_API_KEY=tu_api_key_aqui

